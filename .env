PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# MySQL (NO confundir DB_PORT con PORT del servidor HTTP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=sena_carnets
DB_POOL_LIMIT=10

# Sesión
SESSION_SECRET=dev-session-secret-change-in-production
SESSION_MAX_AGE=28800000

# Uploads
UPLOAD_DIR=public/uploads
UPLOAD_MAX_MB=5

# QR (Módulo 4)
QR_SIGNING_KEY=dev-qr-signing-key
