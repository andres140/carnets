# SENA Carnés — Variables de entorno
# Copiar a .env y ajustar valores

PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=sena_carnets
DB_POOL_LIMIT=10

# Sesión (mínimo 32 caracteres en producción)
SESSION_SECRET=dev-session-secret-change-in-production-min-32-chars
SESSION_MAX_AGE=28800000

# Uploads
UPLOAD_DIR=public/uploads
UPLOAD_MAX_MB=5

# QR (mínimo 32 caracteres en producción)
QR_SIGNING_KEY=dev-qr-signing-key-change-in-production-min-32

# Plantilla PDF carné
CARNET_TEMPLATE_ID=default
CARNET_PDF_DIR=public/uploads/carnets

# Email (opcional — recuperación de contraseña)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@sena.edu.co
